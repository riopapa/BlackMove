<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#333"
    android:id="@+id/ground"
    tools:context=".MainActivity"
    tools:ignore="MissingDefaultResource">

    <Chronometer
        android:id="@+id/chronometerCountDown"
        android:countDown="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center_horizontal"
        android:textSize="60sp"
        android:textColor="#FFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.6"
        app:layout_constraintBottom_toTopOf="@id/comment"
        />

    <TextView
        android:id="@+id/comment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Secs. to restart"
        android:textColor="#FFF"
        android:textSize="24sp"
        app:layout_constraintLeft_toRightOf="@id/add_time_up"
        app:layout_constraintRight_toLeftOf="@id/temperature"
        app:layout_constraintTop_toBottomOf="@id/chronometerCountDown" />

    <ImageButton
        android:id="@+id/exit_app"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#333"
        android:layout_margin="48dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription=""
        android:src="@drawable/exit_black_move" />

    <ImageButton
        android:id="@+id/add_time_up"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#333"
        android:layout_margin="48dp"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/exit_app"
        android:contentDescription=""
        android:src="@drawable/add_more_time" />

    <ImageButton
        android:id="@+id/return2box"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#333"
        android:layout_marginBottom="16dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/comment"
        app:layout_constraintBottom_toBottomOf="parent"
        android:contentDescription=""
        android:src="@mipmap/black_box" />

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="#00000000"
        android:layout_marginBottom="16dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/comment"
        app:layout_constraintBottom_toBottomOf="parent"
        android:contentDescription=""
        android:src="@drawable/return_black_box" />

    <ImageButton
        android:id="@+id/black_move"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="#333"
        android:layout_marginTop="120dp"
        android:layout_marginStart="40dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:contentDescription=""
        android:src="@drawable/car_moving" />

    <TextView
        android:id="@+id/temperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/celsius"
        android:gravity="end"
        android:textColor="#FFF"
        android:text="40 "
        android:textSize="48sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/comment"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/speed_up"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/speed_up"
        android:background="#333"
        app:layout_constraintLeft_toRightOf="@+id/black_move"
        app:layout_constraintBottom_toTopOf="@id/textSpeed"
        android:layout_margin="12dp"
        />
    <TextView
        android:id="@+id/textSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="48sp"
        android:textColor="#DDD"
        android:text="30"
        app:layout_constraintLeft_toRightOf="@id/black_move"
        app:layout_constraintBottom_toTopOf="@id/speed_down"
        android:layout_margin="12dp"
        />
    <ImageButton
        android:id="@+id/speed_down"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="#333"
        android:src="@drawable/speed_down"
        app:layout_constraintLeft_toRightOf="@id/black_move"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="12dp"
        />

    <TextView
        android:id="@+id/celsius"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toRightOf="@id/temperature"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="24dp"
        android:textColor="#FFF"
        android:text=" °C "
        android:textSize="16sp" />


</androidx.constraintlayout.widget.ConstraintLayout>